datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AppointmentStatus {
  disponivel
  reservado
  confirmado
  cancelado
  expirado

  @@map("appointment_status")
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
  REFUNDED

  @@map("payment_status")
}

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome            String    @db.VarChar(255)
  email           String    @unique @db.VarChar(255)
  slug            String    @unique @db.VarChar(100)
  senha           String    @db.VarChar(255)
  telefone        String    @db.VarChar(50)
  reset_token     String?   @db.VarChar(255)
  reset_expires   DateTime? @db.Timestamptz(6)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  services            Service[]
  clients             Client[]
  appointments        Appointment[]
  availability_blocks AvailabilityBlock[]
  theme               ProfessionalTheme?

  @@map("users")
}

model Service {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String   @db.Uuid
  nome            String   @db.VarChar(255)
  descricao       String?  @db.Text
  preco           Decimal  @db.Decimal(10, 2)
  valor_sinal     Decimal  @default(0.00) @db.Decimal(10, 2)
  foto_url        String?  @db.Text
  ativo           Boolean? @default(true)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  appointments Appointment[]

  @@map("services")
}

model Client {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  nome        String   @db.VarChar(255)
  telefone    String   @db.VarChar(50)
  email       String?  @db.VarChar(255)
  observacoes String?  @db.Text
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  appointments Appointment[]

  @@map("clients")
}

model Appointment {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String             @db.Uuid
  client_id     String             @db.Uuid
  service_id    String             @db.Uuid
  data          DateTime           @db.Date
  horario       String             @db.VarChar(5)
  valor_servico Decimal            @db.Decimal(10, 2)
  valor_sinal   Decimal            @db.Decimal(10, 2)
  status        AppointmentStatus? @default(reservado)
  viewed        Boolean?           @default(false)
  expires_at    DateTime?          @db.Timestamptz(6)
  created_at    DateTime?          @default(now()) @db.Timestamptz(6)

  user    User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  client  Client   @relation(fields: [client_id], references: [id], onUpdate: NoAction)
  service Service  @relation(fields: [service_id], references: [id], onUpdate: NoAction)
  payment Payment?

  @@map("appointments")
}

model AvailabilityBlock {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String   @db.Uuid
  data            DateTime @db.Date
  horario_inicio  String   @db.VarChar(5)
  horario_fim     String   @db.VarChar(5)
  duracao_minutos Int
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("availability_blocks")
}

model ProfessionalTheme {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id              String   @unique @db.Uuid
  primary_color        String   @default("#000000") @db.VarChar(7)
  background_type      String   @default("color") @db.VarChar(20)
  background_value     String   @default("#ffffff") @db.Text
  background_image_url String?  @db.Text
  logo_url             String?  @db.Text
  font_family          String   @default("Inter") @db.VarChar(100)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("professional_themes")
}

model Payment {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointment_id String         @unique @db.Uuid
  transaction_id String?        @db.VarChar(255)
  gateway        String?        @default("pagbank") @db.VarChar(50)
  payment_method String?        @db.VarChar(50)
  amount         Decimal        @db.Decimal(10, 2)
  status         PaymentStatus? @default(PENDING)
  pix_qrcode     String?        @db.Text
  pix_copy_paste String?        @db.Text
  paid_at        DateTime?      @db.Timestamptz(6)
  created_at     DateTime?      @default(now()) @db.Timestamptz(6)

  appointment Appointment @relation(fields: [appointment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("payments")
}